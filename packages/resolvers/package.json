{
	"name": "@paradoc/resolvers",
	"version": "0.2.0",
	"description": "Environment-specific resolvers for Paradoc - filesystem, S3, HTTP, etc.",
	"type": "module",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"default": "./dist/index.js"
		}
	},
	"sideEffects": false,
	"files": [
		"dist",
		"README.md",
		"CHANGELOG.md",
		"LICENSE"
	],
	"keywords": [
		"paradoc",
		"paradoc",
		"resolvers",
		"filesystem",
		"storage"
	],
	"license": "MIT",
	"author": {
		"name": "Paradoc",
		"url": "https://paradoc.dev"
	},
	"engines": {
		"node": ">=18"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/paradoc-dev/paradoc.git",
		"directory": "packages/resolvers"
	},
	"homepage": "https://paradoc.dev",
	"bugs": {
		"url": "https://github.com/paradoc-dev/paradoc/issues"
	},
	"publishConfig": {
		"access": "public"
	},
	"scripts": {
		"build": "tsup",
		"dev": "tsup --watch",
		"clean": "rm -rf dist",
		"prebuild": "pnpm run clean",
		"lint": "eslint .",
		"check-types": "tsc --noEmit",
		"check": "pnpm lint && pnpm check-types",
		"test": "vitest run",
		"test:watch": "vitest"
	},
	"dependencies": {
		"@paradoc/types": "workspace:^"
	},
	"devDependencies": {
		"@paradoc/eslint-config": "workspace:*",
		"@paradoc/typescript-config": "workspace:*",
		"@types/node": "catalog:",
		"eslint": "catalog:",
		"tsup": "catalog:",
		"typescript": "catalog:",
		"vitest": "catalog:"
	}
}
