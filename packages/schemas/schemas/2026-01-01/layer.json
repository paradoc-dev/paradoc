{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schema.paradoc.dev/2026-01-01/layer.json",
  "oneOf": [
    {
      "type": "object",
      "properties": {
        "mimeType": {
          "type": "string",
          "minLength": 1,
          "maxLength": 100,
          "description": "MIME type of the layer content (e.g., text/markdown, application/pdf)"
        },
        "title": {
          "type": "string",
          "minLength": 1,
          "maxLength": 200,
          "description": "Human-readable title for this layer"
        },
        "description": {
          "type": "string",
          "minLength": 1,
          "maxLength": 2000,
          "description": "Description of what this layer represents"
        },
        "bindings": {
          "type": "object",
          "propertyNames": {
            "type": "string",
            "minLength": 1,
            "maxLength": 100,
            "description": "Form field name (semantic identifier)"
          },
          "additionalProperties": {
            "type": "string",
            "minLength": 1,
            "maxLength": 500,
            "description": "Target identifier in the template"
          },
          "description": "Mapping from form field names to template target identifiers"
        },
        "bindingsFrom": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128,
          "description": "Key of a sibling layer whose bindings this layer reuses"
        },
        "signatureBlocks": {
          "type": "object",
          "propertyNames": {
            "type": "string",
            "minLength": 1,
            "maxLength": 100,
            "description": "Location ID for the signature block"
          },
          "additionalProperties": {
            "type": "object",
            "properties": {
              "type": {
                "type": "string",
                "enum": [
                  "signature",
                  "initials",
                  "date",
                  "capacity",
                  "printed_name"
                ],
                "description": "Type of signature block: signature/initials (glyph), date (signing date), capacity (signer role/title), or printed_name (typed-out name)"
              },
              "page": {
                "type": "integer",
                "minimum": 1,
                "maximum": 9007199254740991,
                "description": "1-based page number where this block appears"
              },
              "x": {
                "type": "number",
                "minimum": 0,
                "description": "X coordinate in points from left edge of page"
              },
              "y": {
                "type": "number",
                "minimum": 0,
                "description": "Y coordinate in points from top edge of page"
              },
              "width": {
                "type": "number",
                "minimum": 1,
                "description": "Width of the block in points"
              },
              "height": {
                "type": "number",
                "minimum": 1,
                "description": "Height of the block in points"
              },
              "partyRole": {
                "type": "string",
                "minLength": 1,
                "maxLength": 100,
                "description": "Party role this block is bound to (e.g., \"taxpayer\", \"tenant\")"
              },
              "partyIndex": {
                "type": "integer",
                "minimum": 0,
                "maximum": 9007199254740991,
                "description": "0-based index for multi-party roles. Defaults to 0 (first party)"
              },
              "label": {
                "type": "string",
                "minLength": 1,
                "maxLength": 200,
                "description": "Human-readable label for the block"
              },
              "required": {
                "type": "boolean",
                "description": "Whether this block is required. Defaults to true"
              }
            },
            "required": [
              "type",
              "page",
              "x",
              "y",
              "width",
              "height"
            ],
            "additionalProperties": false
          },
          "description": "Pre-defined signature blocks keyed by locationId"
        },
        "kind": {
          "type": "string",
          "const": "inline"
        },
        "text": {
          "type": "string",
          "minLength": 1,
          "maxLength": 1000000,
          "description": "Layer content with interpolation placeholders (e.g., {{fieldName}})"
        }
      },
      "required": [
        "mimeType",
        "kind",
        "text"
      ],
      "additionalProperties": false
    },
    {
      "type": "object",
      "properties": {
        "mimeType": {
          "type": "string",
          "minLength": 1,
          "maxLength": 100,
          "description": "MIME type of the layer content (e.g., text/markdown, application/pdf)"
        },
        "title": {
          "type": "string",
          "minLength": 1,
          "maxLength": 200,
          "description": "Human-readable title for this layer"
        },
        "description": {
          "type": "string",
          "minLength": 1,
          "maxLength": 2000,
          "description": "Description of what this layer represents"
        },
        "bindings": {
          "type": "object",
          "propertyNames": {
            "type": "string",
            "minLength": 1,
            "maxLength": 100,
            "description": "Form field name (semantic identifier)"
          },
          "additionalProperties": {
            "type": "string",
            "minLength": 1,
            "maxLength": 500,
            "description": "Target identifier in the template"
          },
          "description": "Mapping from form field names to template target identifiers"
        },
        "bindingsFrom": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128,
          "description": "Key of a sibling layer whose bindings this layer reuses"
        },
        "signatureBlocks": {
          "type": "object",
          "propertyNames": {
            "type": "string",
            "minLength": 1,
            "maxLength": 100,
            "description": "Location ID for the signature block"
          },
          "additionalProperties": {
            "type": "object",
            "properties": {
              "type": {
                "type": "string",
                "enum": [
                  "signature",
                  "initials",
                  "date",
                  "capacity",
                  "printed_name"
                ],
                "description": "Type of signature block: signature/initials (glyph), date (signing date), capacity (signer role/title), or printed_name (typed-out name)"
              },
              "page": {
                "type": "integer",
                "minimum": 1,
                "maximum": 9007199254740991,
                "description": "1-based page number where this block appears"
              },
              "x": {
                "type": "number",
                "minimum": 0,
                "description": "X coordinate in points from left edge of page"
              },
              "y": {
                "type": "number",
                "minimum": 0,
                "description": "Y coordinate in points from top edge of page"
              },
              "width": {
                "type": "number",
                "minimum": 1,
                "description": "Width of the block in points"
              },
              "height": {
                "type": "number",
                "minimum": 1,
                "description": "Height of the block in points"
              },
              "partyRole": {
                "type": "string",
                "minLength": 1,
                "maxLength": 100,
                "description": "Party role this block is bound to (e.g., \"taxpayer\", \"tenant\")"
              },
              "partyIndex": {
                "type": "integer",
                "minimum": 0,
                "maximum": 9007199254740991,
                "description": "0-based index for multi-party roles. Defaults to 0 (first party)"
              },
              "label": {
                "type": "string",
                "minLength": 1,
                "maxLength": 200,
                "description": "Human-readable label for the block"
              },
              "required": {
                "type": "boolean",
                "description": "Whether this block is required. Defaults to true"
              }
            },
            "required": [
              "type",
              "page",
              "x",
              "y",
              "width",
              "height"
            ],
            "additionalProperties": false
          },
          "description": "Pre-defined signature blocks keyed by locationId"
        },
        "kind": {
          "type": "string",
          "const": "file"
        },
        "path": {
          "type": "string",
          "minLength": 1,
          "maxLength": 1000,
          "description": "Absolute path from repo root to the layer file"
        },
        "checksum": {
          "type": "string",
          "minLength": 1,
          "maxLength": 100,
          "pattern": "^sha256:[a-f0-9]{64}$",
          "description": "SHA-256 checksum for integrity verification"
        }
      },
      "required": [
        "mimeType",
        "kind",
        "path"
      ],
      "additionalProperties": false
    }
  ],
  "title": "Layer"
}