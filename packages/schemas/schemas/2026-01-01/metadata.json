{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schema.paradoc.dev/2026-01-01/metadata.json",
  "type": "object",
  "propertyNames": {
    "type": "string",
    "minLength": 1,
    "maxLength": 100,
    "pattern": "^[A-Za-z0-9]([A-Za-z0-9]|-[A-Za-z0-9])*$",
    "description": "Metadata key identifier. Must start with alphanumeric character and can contain alphanumeric characters and hyphens"
  },
  "additionalProperties": {
    "anyOf": [
      {
        "type": "string",
        "maxLength": 500,
        "description": "Metadata value as a string (max 500 characters)"
      },
      {
        "type": "number",
        "description": "Metadata value as a number"
      },
      {
        "type": "boolean",
        "description": "Metadata value as a boolean"
      },
      {
        "type": "null",
        "description": "Metadata value as null"
      }
    ]
  },
  "title": "Metadata"
}