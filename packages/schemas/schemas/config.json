{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schema.paradoc.dev/config.json",
  "type": "object",
  "properties": {
    "$schema": {
      "type": "string",
      "format": "uri",
      "description": "JSON Schema URI for validation"
    },
    "registries": {
      "type": "object",
      "propertyNames": {
        "type": "string",
        "pattern": "^@[a-zA-Z0-9][a-zA-Z0-9-_]*$",
        "description": "Registry namespace (must start with @)"
      },
      "additionalProperties": {
        "$ref": "#/$defs/RegistryEntry"
      },
      "description": "Configured registries by namespace"
    },
    "defaults": {
      "$ref": "#/$defs/GlobalDefaults"
    },
    "cache": {
      "type": "object",
      "properties": {
        "ttl": {
          "default": 3600,
          "description": "Default cache TTL in seconds. 0 disables caching. Default: 3600 (1 hour)",
          "type": "integer",
          "minimum": 0,
          "maximum": 9007199254740991
        },
        "directory": {
          "type": "string",
          "description": "Custom cache directory path. Default: ~/.paradoc/cache"
        }
      },
      "additionalProperties": false,
      "title": "CacheConfig",
      "description": "Global cache configuration for registry data"
    },
    "enableTelemetry": {
      "default": true,
      "description": "Enable anonymous usage telemetry for artifact installs. Overrides registry settings when false. Defaults to true.",
      "type": "boolean"
    }
  },
  "additionalProperties": false,
  "$defs": {
    "RegistryEntry": {
      "anyOf": [
        {
          "type": "string",
          "format": "uri",
          "description": "Simple registry URL"
        },
        {
          "$ref": "#/$defs/RegistryEntryObject"
        }
      ],
      "title": "RegistryEntry",
      "description": "Registry configuration - URL string or object with authentication"
    },
    "RegistryEntryObject": {
      "type": "object",
      "properties": {
        "url": {
          "type": "string",
          "format": "uri",
          "description": "Registry base URL"
        },
        "headers": {
          "type": "object",
          "propertyNames": {
            "type": "string"
          },
          "additionalProperties": {
            "type": "string"
          },
          "description": "HTTP headers for authentication (supports ${ENV_VAR} expansion)"
        },
        "params": {
          "type": "object",
          "propertyNames": {
            "type": "string"
          },
          "additionalProperties": {
            "type": "string"
          },
          "description": "Query parameters to include in requests"
        },
        "cache": {
          "type": "object",
          "properties": {
            "ttl": {
              "type": "integer",
              "minimum": 0,
              "maximum": 9007199254740991,
              "description": "Cache TTL in seconds. 0 disables caching for this registry."
            }
          },
          "additionalProperties": false,
          "title": "RegistryCacheConfig",
          "description": "Per-registry cache settings"
        }
      },
      "required": [
        "url"
      ],
      "additionalProperties": false,
      "title": "RegistryEntryObject",
      "description": "Registry configuration with authentication options"
    },
    "GlobalDefaults": {
      "type": "object",
      "properties": {
        "output": {
          "default": "json",
          "description": "Default output format for artifacts: json, yaml, typed (json + .d.ts), or ts (TypeScript module)",
          "anyOf": [
            {
              "type": "string",
              "const": "json"
            },
            {
              "type": "string",
              "const": "yaml"
            },
            {
              "type": "string",
              "const": "typed"
            },
            {
              "type": "string",
              "const": "ts"
            }
          ],
          "title": "GlobalArtifactOutputFormat"
        },
        "artifactsDir": {
          "default": "artifacts",
          "description": "Default directory for installed artifacts",
          "type": "string"
        },
        "registry": {
          "type": "string",
          "pattern": "^@[a-zA-Z0-9][a-zA-Z0-9-_]*$",
          "description": "Default registry namespace for artifact operations (must start with @)"
        }
      },
      "additionalProperties": false,
      "title": "GlobalDefaults",
      "description": "Default settings for CLI operations"
    }
  }
}