{
  "name": "@paradoc/sdk",
  "version": "0.1.1",
  "description": "Umbrella package for Paradoc framework - re-exports @paradoc/core, @paradoc/renderers, and @paradoc/serialization",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "sideEffects": false,
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "keywords": [
    "paradoc",
    "paradoc",
    "sdk",
    "forms",
    "rendering",
    "schemas",
    "validation"
  ],
  "license": "MIT",
  "author": {
    "name": "Paradoc",
    "url": "https://paradoc.dev"
  },
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/paradoc-dev/paradoc.git",
    "directory": "packages/sdk"
  },
  "homepage": "https://paradoc.dev",
  "bugs": {
    "url": "https://github.com/paradoc-dev/paradoc/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist",
    "prebuild": "pnpm run clean",
    "pack:dry": "pnpm run build && npm pack --dry-run",
    "prepublishOnly": "pnpm run build",
    "lint": "eslint .",
    "check-types": "tsc --noEmit",
    "check": "pnpm lint && pnpm check-types && echo \"✅ All checks passed\" || echo \"❌ Checks failed\""
  },
  "dependencies": {
    "@paradoc/core": "workspace:*",
    "@paradoc/renderers": "workspace:*",
    "@paradoc/serialization": "workspace:*"
  },
  "devDependencies": {
    "@paradoc/eslint-config": "workspace:*",
    "@paradoc/typescript-config": "workspace:*",
    "@types/node": "catalog:",
    "eslint": "catalog:",
    "tsup": "catalog:",
    "typescript": "catalog:"
  }
}
