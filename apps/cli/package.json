{
  "name": "@paradoc/cli",
  "version": "0.1.1",
  "description": "CLI tool for Paradoc framework",
  "type": "module",
  "bin": {
    "para": "./dist/index.js",
    "paradoc": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "keywords": [
    "paradoc",
    "paradoc",
    "cli",
    "forms",
    "command-line"
  ],
  "license": "MIT",
  "author": "Paradoc",
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/paradoc-dev/paradoc.git",
    "directory": "apps/cli"
  },
  "homepage": "https://www.paradoc.dev",
  "bugs": {
    "url": "https://github.com/paradoc-dev/paradoc/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup src/index.ts --format esm --dts --watch",
    "start": "tsx src/index.ts",
    "clean": "rm -rf dist",
    "prebuild": "pnpm run clean",
    "pack:dry": "pnpm run build && npm pack --dry-run",
    "prepublishOnly": "pnpm run build",
    "lint": "eslint .",
    "check-types": "tsc --noEmit",
    "check": "pnpm lint && pnpm check-types",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test-registry": "tsx test-registry/server.ts"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "diff": "^8.0.2",
    "fast-glob": "^3.3.3",
    "kleur": "^4.1.5",
    "open": "^10.2.0",
    "ora": "^9.0.0",
    "prompts": "^2.4.2",
    "safe-regex": "^2.1.1",
    "semver": "^7.7.3",
    "slugify": "^1.6.6",
    "undici": "^7.22.0",
    "yaml": "catalog:"
  },
  "devDependencies": {
    "@paradoc/core": "workspace:*",
    "@paradoc/eslint-config": "workspace:*",
    "@paradoc/renderer-text": "workspace:*",
    "@paradoc/renderer-pdf": "workspace:*",
    "@paradoc/renderer-docx": "workspace:*",
    "zod": "catalog:",
    "@paradoc/schemas": "workspace:*",
    "@paradoc/typescript-config": "workspace:*",
    "@types/node": "catalog:",
    "@types/prompts": "^2.4.9",
    "@types/semver": "^7.7.1",
    "@vitest/coverage-v8": "catalog:",
    "eslint": "catalog:",
    "tsup": "catalog:",
    "tsx": "^4.20.6",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
